# ARIA - Environment Variables
# All API Keys for AI Features

# ============== REQUIRED ==============

# Anthropic API Key (Claude AI)
# Get FREE key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============== AI MODELS ==============

# Google Gemini API Key
# Get FREE key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (GPT-4, GPT-3.5)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============== AI MEMORY ==============

# Mem0 API Key (Memory layer for AI)
# Get key from: https://app.mem0.ai/api-keys
MEM0_API_KEY=your_mem0_api_key_here

# ============== REAL-TIME COMMUNICATION ==============

# LiveKit API (Real-time audio/video)
# Get keys from: https://cloud.livekit.io/projects/p_/keys
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
LIVEKIT_URL=wss://your-project.livekit.cloud

# ============== VOICE GENERATION ==============

# ElevenLabs API Key (AI Voice Generation - Better than pyttsx3)
# Get FREE key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=Rachel

# ============== OPTIONAL ==============

# News API Key (for news headlines)
# Get FREE key from: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Weather API Key (optional - uses wttr.in if not set)
WEATHER_API_KEY=

# ============== SERVER CONFIGURATION ==============

# Server port
PORT=8000

# Server host (default: localhost)
HOST=127.0.0.1

# ============== INSTRUCTIONS ==============
# 
# 1. Get your FREE API keys from the links above
# 2. Replace 'your_xxx_api_key_here' with actual keys
# 3. Save this file
# 4. Run: python main.py
# 5. Open: http://localhost:8000
#
# FREE Tiers Available:
# - Anthropic: ~100 requests/day free
# - Google Gemini: 60 requests/minute free
# - OpenAI: $5 free credit for new accounts
# - ElevenLabs: 10,000 characters/month free
# - LiveKit: Free tier available
# - Mem0: Free tier available
