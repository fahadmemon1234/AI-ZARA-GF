# ================================================
# ARIA Specific (Keep these!)
# ================================================
# Keep config and code, ignore only user data
config.py  # Keep this (has default values)
main.py    # Keep this
modules/   # Keep all modules
public/    # Keep frontend
requirements.txt  # Keep this
README.md  # Keep this
FEATURES_GUIDE.md  # Keep this

# But ignore runtime data
*.pid
*.lock
*.sqlite
*.db
