# ================================================
# ZARA - .gitignore
# ================================================

# ================================================
# ⚠️ CRITICAL: NEVER UPLOAD TO GITHUB
# ================================================
# These files contain API keys and sensitive data
# They are IGNORED from git - will NOT be uploaded!

.env                    # API keys - NEVER commit!
.env.local
.env.*.local
data/*.json            # User data - NEVER commit!
data/memory.json
data/conversations.json

# ================================================
# Python
# ================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
venv/
ENV/
env/
.venv

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

